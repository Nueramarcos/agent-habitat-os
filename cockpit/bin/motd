#!/usr/bin/env bash
HOST=$(hostname -s 2>/dev/null || echo linux)
PROFILE=$(cat "$HOME/.config/agent-habitat/profile" 2>/dev/null || echo hybrid)

quotes=(
  "Boot the workshop. Ship the PR."
  "Cloud plans. Local executes. Flight recorder proves it."
  "Agent-native means known paths, not guesswork."
  "Twenty minutes to first merge — that's the bar."
)
q="${quotes[$((RANDOM % ${#quotes[@]}))]}"

printf '\n\033[38;5;141m▓▒░\033[0m \033[1m%s\033[0m \033[38;5;141m░▒▓\033[0m  profile=\033[1m%s\033[0m\n' "$HOST" "$PROFILE"
printf '\033[3m%s\033[0m\n\n' "$q"
printf '  \033[1mhabitat verify\033[0m · \033[1mgrok\033[0m · \033[1missue-agent status\033[0m\n\n'
#!/usr/bin/env bash
# Agent Habitat OS — main CLI
set -euo pipefail

habitat_resolve_root() {
  if [[ -n "${HABITAT_ROOT:-}" && -f "$HABITAT_ROOT/first-boot/install.sh" ]]; then
    printf '%s' "$HABITAT_ROOT"
    return
  fi
  if [[ -f "$HOME/agent-habitat-os/first-boot/install.sh" ]]; then
    printf '%s' "$HOME/agent-habitat-os"
    return
  fi
  local script
  script="$(readlink -f "${BASH_SOURCE[0]}")"
  if [[ -f "$(dirname "$script")/../first-boot/install.sh" ]]; then
    cd "$(dirname "$script")/.." && pwd
    return
  fi
  die "cannot find agent-habitat-os — clone to ~/agent-habitat-os or set HABITAT_ROOT"
}

HABITAT_ROOT="$(habitat_resolve_root)"
CONFIG_DIR="$HOME/.config/agent-habitat"
PROFILE_FILE="$CONFIG_DIR/profile"

usage() {
  cat <<EOF
habitat — Agent Habitat OS CLI

Usage:
  habitat install [profile]     Provision workstation (hybrid|minimal|cloud-only)
  habitat init                  First-time wizard (gh, grok, repos.yaml)
  habitat verify                Health check (16 checks)
  habitat status                Cockpit + issue-agent status
  habitat profile show|set <n>  Active routing profile
  habitat demo                  Run demo pytest lane
  habitat ci-setup [owner/repo] Push demo CI workflow (needs workflow scope)
  habitat iso [prepare|stage|seed|download|vm|vm-status]
  habitat docs                  Open README

EOF
}

cmd_install() {
  local profile="${1:-hybrid}"
  export HABITAT_PROFILE="$profile"
  bash "$HABITAT_ROOT/first-boot/install.sh"
}

cmd_verify() {
  bash "$HABITAT_ROOT/first-boot/verify.sh"
}

cmd_status() {
  echo "═══ Agent Habitat Status ═══"
  echo "Root:    $HABITAT_ROOT"
  echo "Profile: $(cat "$PROFILE_FILE" 2>/dev/null || echo unset)"
  echo ""
  command -v cockpit >/dev/null 2>&1 && cockpit || true
  echo ""
  if command -v issue-agent >/dev/null 2>&1; then
    issue-agent status --quick 2>/dev/null || issue-agent status 2>/dev/null || true
  else
    echo "issue-agent: not installed (cloud-only profile or install pending)"
  fi
}

cmd_profile() {
  local sub="${1:-show}"
  shift || true
  mkdir -p "$CONFIG_DIR"
  case "$sub" in
    show)
      local p
      p="$(cat "$PROFILE_FILE" 2>/dev/null || echo hybrid)"
      echo "Active profile: $p"
      echo "Config: $HABITAT_ROOT/profiles/${p}.yaml"
      [[ -f "$HABITAT_ROOT/profiles/${p}.yaml" ]] && cat "$HABITAT_ROOT/profiles/${p}.yaml"
      ;;
    set)
      local name="${1:-}"
      [[ -z "$name" ]] && die "usage: habitat profile set <hybrid|minimal|cloud-only>"
      [[ -f "$HABITAT_ROOT/profiles/${name}.yaml" ]] || die "unknown profile: $name"
      echo "$name" > "$PROFILE_FILE"
      export HABITAT_PROFILE="$name"
      echo "Profile set to $name — run 'habitat install' to apply"
      ;;
    *)
      die "usage: habitat profile show|set <name>"
      ;;
  esac
}

cmd_init() {
  bash "$HABITAT_ROOT/first-boot/init.sh"
}

cmd_ci_setup() {
  bash "$HABITAT_ROOT/scripts/setup-demo-ci.sh" "${1:-Nueramarcos/agent-habitat-demo}"
}

cmd_iso() {
  local sub="${1:-prepare}"
  shift || true
  case "$sub" in
    prepare|usb)
      bash "$HABITAT_ROOT/iso/prepare-usb.sh"
      ;;
    seed)
      bash "$HABITAT_ROOT/iso/scripts/create-seed-iso.sh"
      ;;
    download)
      bash "$HABITAT_ROOT/iso/scripts/download-ubuntu-iso.sh"
      ;;
    vm|qemu|test)
      bash "$HABITAT_ROOT/iso/scripts/qemu-test.sh"
      ;;
    vm-gui)
      bash "$HABITAT_ROOT/iso/scripts/qemu-gui.sh"
      ;;
    smoke)
      bash "$HABITAT_ROOT/iso/scripts/qemu-smoke.sh"
      ;;
    watch)
      bash "$HABITAT_ROOT/iso/scripts/vm-watch.sh"
      ;;
    vm-status|status)
      local log="$HABITAT_ROOT/iso/build/qemu-serial.log"
      local pidfile="$HABITAT_ROOT/iso/build/qemu.pid"
      if [[ -f "$pidfile" ]] && kill -0 "$(cat "$pidfile")" 2>/dev/null; then
        echo "QEMU running pid=$(cat "$pidfile")"
      else
        echo "QEMU not running"
      fi
      if [[ -f "$log" ]]; then
        echo "--- serial log (last 20 lines) ---"
        tail -20 "$log"
        echo ""
        if grep -qiE 'autoinstall|subiquity|curtin|agent-habitat' "$log" 2>/dev/null; then
          echo "✓ autoinstall/habitat signals detected in log"
        fi
      fi
      ;;
    ssh)
      bash "$HABITAT_ROOT/iso/scripts/vm-ssh.sh" "$@"
      ;;
    boot-disk)
      bash "$HABITAT_ROOT/iso/scripts/vm-boot-disk.sh"
      ;;
    console)
      bash "$HABITAT_ROOT/iso/scripts/vm-console.sh"
      ;;
    provision)
      bash "$HABITAT_ROOT/iso/scripts/vm-provision.sh" "$@"
      ;;
    peek)
      bash "$HABITAT_ROOT/iso/scripts/vm-peek.sh"
      ;;
    stop)
      /usr/bin/pkill -f 'qemu-system.*agent-habitat-test' 2>/dev/null && echo "QEMU stopped" || echo "no VM running"
      rm -f "$HABITAT_ROOT/iso/build/qemu.pid" "$HABITAT_ROOT/iso/build/qemu-disk.pid" 2>/dev/null
      ;;
    stage|build)
      bash "$HABITAT_ROOT/iso/build-iso.sh"
      ;;
    *)
      die "usage: habitat iso prepare|seed|download|vm|vm-gui|boot-disk|console|provision|ssh|watch|stop|stage"
      ;;
  esac
}

cmd_demo() {
  local demo="$HABITAT_ROOT/demo/agent-habitat-demo"
  echo "═══ Agent Habitat Demo ═══"
  echo "Demo repo: $demo"
  echo "Remote:    https://github.com/Nueramarcos/agent-habitat-demo"
  echo ""
  cd "$demo"
  local venv="$demo/.venv"
  if [[ ! -x "$venv/bin/pytest" ]]; then
    python3 -m venv "$venv"
    "$venv/bin/pip" install -q pytest
  fi
  echo "Running local tests..."
  if "$venv/bin/python" -m pytest -q 2>&1; then
    echo ""
    echo "All tests pass locally."
    echo "Open a new agent-triage issue on GitHub for the next autonomous run:"
    echo "  gh issue create -R Nueramarcos/agent-habitat-demo --label agent-triage ..."
    echo "  issue-agent fix Nueramarcos/agent-habitat-demo <N>"
  else
    echo ""
    echo "Tests failing. Fix with:"
    echo "  grok -p 'Fix habitat/calc.py so all tests pass'"
    echo "  issue-agent fix Nueramarcos/agent-habitat-demo <issue>"
  fi
}

die() { echo "habitat: $*" >&2; exit 1; }

main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    install)       cmd_install "$@" ;;
    init)          cmd_init ;;
    verify|check)  cmd_verify ;;
    status)        cmd_status ;;
    profile)       cmd_profile "$@" ;;
    demo)          cmd_demo ;;
    ci-setup|ci)   cmd_ci_setup "$@" ;;
    ci-auth)       bash "$HABITAT_ROOT/scripts/ci-auth.sh" ;;
    iso)           cmd_iso "$@" ;;
    docs)          less "$HABITAT_ROOT/README.md" 2>/dev/null || cat "$HABITAT_ROOT/README.md" ;;
    ""|help|-h)    usage ;;
    *)             die "unknown command: $cmd (try: habitat help)" ;;
  esac
}

main "$@"